# RentCast API Smoke Test Configuration
# Copy this file to .env and fill in your actual values
# The .env file will be automatically loaded when running tests

# Your RentCast API Key (get it from https://app.rentcast.io/app/api)
# This is the only required setting - all tests will run if this is set
RENTCAST_API_KEY=your-api-key-here

# (Optional) Override the API base URL
# RENTCAST_API_BASE_URL=https://api.rentcast.io/v1

# (Optional) Request timeout in milliseconds
# RENTCAST_TIMEOUT=30000

# (Optional) Enable verbose logging
# RENTCAST_VERBOSE=true

# INSTRUCTIONS:
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Edit .env and replace 'your-api-key-here' with your actual RentCast API key
#
# 3. Run tests:
#    npm test
#
# The .env file is automatically loaded by dotenv when the program starts.
# Never commit .env to version control - it contains sensitive information.

